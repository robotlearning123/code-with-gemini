{
  "name": "wanman-h-29517",
  "version": "0.1.0",
  "description": "Interactive Gemini chat client — Code With Gemini hackathon submission",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "gemini-chat": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc && node -e \"const f='dist/cli.js';const c=require('fs').readFileSync(f,'utf8');if(!c.startsWith('#!'))require('fs').writeFileSync(f,'#!/usr/bin/env node\\n'+c)\"",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.1.0",
    "@types/node": "^22.0.0"
  }
}
