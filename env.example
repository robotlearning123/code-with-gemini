# Required: Your Google AI Studio API key
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-api-key-here

# Optional: Model to use (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# Optional: Max conversation turns to keep (default: 20)
# GEMINI_MAX_HISTORY=20

# Optional: System instruction for the model
# GEMINI_SYSTEM_PROMPT=You are a concise coding assistant.

# Optional: Generation config (controls response behavior)
# GEMINI_TEMPERATURE=0.7        # Sampling temperature 0-2
# GEMINI_TOP_P=0.9             # Top-P nucleus sampling 0-1
# GEMINI_TOP_K=40              # Top-K sampling (>= 1)
# GEMINI_MAX_OUTPUT_TOKENS=2048  # Max tokens in response
